<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">
    <welcome-file-list>
        <welcome-file>landing</welcome-file>
    </welcome-file-list>
    <display-name>Badminton Court Booking System</display-name>
    <servlet-mapping>
        <servlet-name>default</servlet-name>
        <url-pattern>*.css</url-pattern>
        <url-pattern>*.js</url-pattern>
        <url-pattern>*.jpg</url-pattern>
        <url-pattern>*.jpeg</url-pattern>
        <url-pattern>*.png</url-pattern>
        <url-pattern>*.gif</url-pattern>
        <url-pattern>*.svg</url-pattern>
        <url-pattern>*.ico</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RegisterController</servlet-name>
        <servlet-class>com.bcb.controller.RegisterController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>VerifyEmailController</servlet-name>
        <servlet-class>com.bcb.controller.VerifyEmailController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>CleanupEmailVerificationController</servlet-name>
        <servlet-class>com.bcb.controller.CleanupEmailVerificationController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>GoogleLoginServlet</servlet-name>
        <servlet-class>com.bcb.controller.GoogleLoginServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.bcb.controller.LoginServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>GoogleAutoLinkController</servlet-name>
        <servlet-class>com.bcb.controller.GoogleAutoLinkController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>GoogleCallbackController</servlet-name>
        <servlet-class>com.bcb.controller.GoogleCallbackController</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>RegisterController</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>VerifyEmailController</servlet-name>
        <url-pattern>/verify-email</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>CleanupEmailVerificationController</servlet-name>
        <url-pattern>/cleanup-email</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>GoogleLoginServlet</servlet-name>
        <url-pattern>/google-login</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>GoogleAutoLinkController</servlet-name>
        <url-pattern>/google-link</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>GoogleCallbackController</servlet-name>
        <url-pattern>/google-callback</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ForgotPasswordController</servlet-name>
        <servlet-class>com.bcb.controller.ForgotPasswordController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ForgotPasswordController</servlet-name>
        <url-pattern>/forgot-password</url-pattern>
    </servlet-mapping>

    <servlet>
	    <servlet-name>ReviewController</servlet-name>
	    <servlet-class>com.bcb.controller.review.ReviewController</servlet-class>
	</servlet>
	<servlet-mapping>
	    <servlet-name>ReviewController</servlet-name>
	    <url-pattern>/reviews</url-pattern>
	</servlet-mapping>

    <servlet>
        <servlet-name>InventoryController</servlet-name>
        <servlet-class>com.bcb.controller.owner.InventoryController</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>InventoryController</servlet-name>
        <url-pattern>/owner/inventory</url-pattern>
    </servlet-mapping>

    <servlet>
    <servlet-name>OwnerFacilityInventoryController</servlet-name>
    <servlet-class>
        com.bcb.controller.owner.OwnerFacilityInventoryController
    </servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>OwnerFacilityInventoryController</servlet-name>
    <url-pattern>/owner/facility/inventory/*</url-pattern>
</servlet-mapping>
</web-app>
